# Public, non-secret defaults. Committed to the repo.
#
# Secrets (API keys, anything machine-specific) live in .env.local, which is
# gitignored. See .env.local.example for the template and the README for how
# to load both files into your shell.
#
# The REPL reads os.environ directly (no python-dotenv auto-load), so make
# sure both .env and .env.local are sourced in the same terminal where you
# run `python -m mathagent`.

# ---- LangSmith tracing (default backend) ----
# Set to "true" to send traces to LangSmith. If unset or "false", LangChain
# runs without tracing. The API key itself lives in .env.local.
LANGCHAIN_TRACING_V2=true

# Project name that traces are grouped under in the LangSmith UI.
LANGCHAIN_PROJECT=mathagent

# LangSmith endpoint. Leave the default unless you use a self-hosted instance.
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ---- Tracing backend selector ----
# Controls which callback handlers tracing.get_callbacks() returns. Missing
# keys for either backend produce graceful degradation: LangSmith silently
# skips uploads, LangFuse prints one "client will be disabled" warning at
# startup and then no-ops. The agent runs either way.
#   both       (default): both backends.
#   langsmith           : LangSmith only. Set this if you have no LangFuse keys and want to skip the startup warning.
#   langfuse            : LangFuse only. Also unset LANGCHAIN_TRACING_V2 to silence LangSmith.
#   none                : no callbacks at all.
TRACING_BACKEND=both

# ---- LangFuse non-secret config (only used when TRACING_BACKEND is langfuse or both) ----
# Targets LangFuse v3+ (we install v4). The integration uses
# `langfuse.langchain.CallbackHandler`; the legacy `langfuse.callback` import
# path was removed in v3.
#
# Cloud EU is the default. Use https://us.cloud.langfuse.com or your
# self-hosted URL otherwise. The keys themselves live in .env.local.
#
# Name note: LangFuse v3+ prefers LANGFUSE_BASE_URL; LANGFUSE_HOST is the
# legacy name and still read as a fallback. The official "create API key"
# UI tells new users to set LANGFUSE_BASE_URL, so we use that.
LANGFUSE_BASE_URL=https://cloud.langfuse.com
