# Copy this file to .env (or .env.local for machine-specific secrets) and fill in.
# python-dotenv is NOT auto-loaded. The REPL reads os.environ directly. See README
# "Environment variables" for how to source the file on each shell.

# ---- LangSmith tracing (default backend) ----
# Set to "true" to send traces to LangSmith. If unset or "false", LangChain runs
# without tracing.
LANGCHAIN_TRACING_V2=true

# Your LangSmith API key. Get it at https://smith.langchain.com/ (Settings -> API Keys).
LANGCHAIN_API_KEY=

# Project name that traces are grouped under in the LangSmith UI.
LANGCHAIN_PROJECT=mathagent

# LangSmith endpoint. Leave the default unless you use a self-hosted instance.
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ---- Tracing backend selector ----
# Controls which callback handlers tracing.get_callbacks() returns.
#   langsmith  (default): rely on LANGCHAIN_TRACING_V2 above. No extra handlers needed.
#   langfuse           : add the LangFuse handler. Disables LangSmith if you also unset LANGCHAIN_TRACING_V2.
#   both               : add LangFuse on top of LangSmith. Useful for migration / comparison.
#   none               : no callbacks at all.
TRACING_BACKEND=langsmith

# ---- LangFuse (only used when TRACING_BACKEND is langfuse or both) ----
# Sign up at https://cloud.langfuse.com/ (or self-host). Project Settings -> API Keys.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Cloud EU is the default. Use https://us.cloud.langfuse.com or your self-hosted URL otherwise.
LANGFUSE_HOST=https://cloud.langfuse.com
