# Template for secrets and machine-specific overrides. Committed.
#
# Copy this file to `.env.local` (which is gitignored) and fill in the keys.
# Anything in `.env.local` overrides the same variable in `.env`.
#
# The REPL reads os.environ directly, so source `.env` and then `.env.local`
# in the same terminal before running `python -m mathagent`. The README
# section "Load the env vars into your shell" has the platform-specific
# commands.

# ---- LangSmith ----
# Required when LANGCHAIN_TRACING_V2 is true (the default in `.env`).
# Get a key at https://smith.langchain.com/ -> Settings -> API Keys -> Create.
LANGCHAIN_API_KEY=

# ---- LangFuse ----
# Required only when TRACING_BACKEND is `langfuse` or `both`.
# Sign up at https://cloud.langfuse.com/ (or self-host), then in your project
# go to Settings -> API Keys -> Create new API keys.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
